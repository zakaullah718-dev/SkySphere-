# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# WEATHER_API_KEY: Required for future Weather API requests (e.g. WeatherAPI).
# Configure this via the Secrets panel in AI Studio.
WEATHER_API_KEY=PLACEholder_WEATHER_API_KEY

# MAPTILER_API_KEY: Required for high-performance vector basemaps.
# Configure this via the Secrets panel in AI Studio.
MAPTILER_API_KEY=PLACEholder_MAPTILER_API_KEY
